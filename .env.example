# ========================================
# Jazyk a Integrace - Environment Variables
# ========================================
# Copy this file to .env and fill in your values

# ----------------------------------------
# Site Configuration
# ----------------------------------------
# Canonical site URL for SEO (used in meta tags, sitemap, JSON-LD)
# Example: https://jazykaintegrace.cz
VITE_SITE_URL=

# ----------------------------------------
# Lead Magnet Form
# ----------------------------------------
# Optional: Form submission endpoint (e.g., Formspree, custom API)
# If not set, the form opens the user's email client with a prefilled message
# Example: https://formspree.io/f/your-form-id
VITE_LEAD_FORM_ENDPOINT=

# ----------------------------------------
# Supabase Authentication & Database
# ----------------------------------------
# Required for student signup, onboarding, and course enrollment
# Get these from: https://app.supabase.com/project/_/settings/api
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ----------------------------------------
# Stripe Payment Integration (Optional)
# ----------------------------------------
# Required for course checkout and payment processing
# Get publishable key from: https://dashboard.stripe.com/apikeys
VITE_STRIPE_PUBLISHABLE_KEY=

# Stripe checkout endpoint (Supabase Edge Function)
# Format: https://<project-ref>.functions.supabase.co/make-server-342a80aa/stripe/checkout
VITE_STRIPE_CHECKOUT_ENDPOINT=

# Stripe Price ID for course enrollment (from Stripe Dashboard -> Products)
# Example: price_1A2B3C4D5E6F7G8H9
VITE_STRIPE_PRICE_ID=

# Default cohort ID to use if no specific cohort is selected
# This should match a record in your Supabase `cohorts` table
VITE_DEFAULT_COHORT_ID=

# ----------------------------------------
# Analytics
# ----------------------------------------
# PostHog Analytics (for user behavior tracking and product insights)
# Get these from: https://app.posthog.com/project/settings
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://app.posthog.com

# ----------------------------------------
# Server-Side Environment Variables
# ----------------------------------------
# These are used by Supabase Edge Functions (not in the client bundle)
# Set these in: Supabase Dashboard -> Edge Functions -> Environment Variables

# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# SUPABASE_URL=https://...supabase.co
# SUPABASE_ANON_KEY=eyJ...
# SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ----------------------------------------
# Development Notes
# ----------------------------------------
# 1. Run `supabase/schema.sql` in Supabase SQL editor to create tables
# 2. Seed `courses` and `cohorts` tables so CourseList displays data
# 3. Test lead form submission before deploying to production
# 4. Configure Stripe webhook for payment confirmation events
